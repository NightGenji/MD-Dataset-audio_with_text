======================== Set Up =====================================
sudo apt update
sudo apt install python3-tk ffmpeg python3-venv python3-pip
python3 -m venv v_environment
source v_environment/bin/activate

pip install -r requirements.txt
pip install -r req_just_edit.txt

export PS1="\u@\h:\W\$ "   // pentru scurtarea terminalului


